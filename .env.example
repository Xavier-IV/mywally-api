NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgresql://mywally:mywally@localhost:5433/mywally?schema=public

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_SECRET=replace-me-in-prod
JWT_EXPIRES_IN=7d

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=false

# Public base URL (for Twilio webhooks; use Cloudflare Tunnel / ngrok)
PUBLIC_BASE_URL=http://localhost:3000

# TNG webhook auth (HMAC shared secret with TNG, mocked locally)
TNG_WEBHOOK_SECRET=tng-dev-secret
TNG_VALIDATE_SIGNATURE=false

# Timeouts (seconds)
PUSH_TIMEOUT_SECONDS=60
CALL_TIMEOUT_SECONDS=90

# Demo mode: skip real Twilio calls, log instead
DEMO_FAKE_VOICE=true
