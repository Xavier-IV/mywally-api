NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgresql://mywally:mywally@localhost:5433/mywally?schema=public

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_SECRET=replace-me-in-prod
JWT_EXPIRES_IN=7d

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=false

# Public base URL (for Twilio webhooks; use Cloudflare Tunnel / ngrok)
PUBLIC_BASE_URL=http://localhost:3000

# TNG webhook auth (HMAC shared secret with TNG, mocked locally)
TNG_WEBHOOK_SECRET=tng-dev-secret
TNG_VALIDATE_SIGNATURE=false

# Timeouts (seconds)
PUSH_TIMEOUT_SECONDS=60
CALL_TIMEOUT_SECONDS=90

# Demo mode: skip real Twilio calls, log instead
DEMO_FAKE_VOICE=true

# LLM provider for the chatbot. Configure one - service auto-picks if multiple.
# Explicit override: bedrock | alibaba | anthropic | moonshot | empty=auto
LLM_PROVIDER=bedrock

# AWS Bedrock (preferred - data residency in Singapore)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=ap-southeast-1
BEDROCK_MODEL=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Anthropic direct
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Moonshot (OpenAI-compatible)
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-32k
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Alibaba DashScope / Qwen (OpenAI-compatible). Strategic alignment with TNG (Ant Group).
ALIBABA_API_KEY=
ALIBABA_MODEL=qwen-max-latest
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
